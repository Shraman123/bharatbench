GROQ_API_KEY=your_groq_api_key_here

# Only needed if you evaluate an openai-alias model (see eval/config.py MODELS)
OPENAI_API_KEY=your_openai_api_key_here
# Optional: point at any OpenAI-compatible endpoint instead of api.openai.com
OPENAI_BASE_URL=

# Only needed if you evaluate a sarvam-alias model
SARVAM_API_KEY=your_sarvam_api_key_here

# Optional: point the judge at a different provider/model than any subject
# being evaluated, to avoid the judge-is-also-a-subject problem. Both must be
# set together. See README.md#known-limitations.
# JUDGE_PROVIDER=openai
# JUDGE_MODEL_ID=gpt-4o-mini
